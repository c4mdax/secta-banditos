---
import { getCollection } from 'astro:content';

// Fetch all the markdown files from the meetings folder
const meetings = await getCollection('meetings');

// Optional: Sort them by date if you want the newest first
// meetings.sort((a, b) => new Date(a.data.date).valueOf() - new Date(b.data.date).valueOf());
---

<div class="max-w-[1000px] mx-auto px-4 sm:px-6">
  <div class="grid gap-6 md:grid-cols-2">
    {
      meetings.map((meeting) => (
        <div class="bg-base-100 p-8 rounded-xl shadow-lg border border-base-content/10 hover:border-primary transition-colors group">
          
          <div class="text-primary font-bold text-sm tracking-widest uppercase mb-2">
            {meeting.data.date}
          </div>
          
          <h3 class="text-2xl font-bold mb-3 group-hover:text-primary transition-colors">
            {meeting.data.title}
          </h3>
          
          <div class="flex items-center gap-2 text-base-content/70 mb-4 text-sm font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {meeting.data.location}
          </div>
          
          <p class="text-base-content/80 leading-relaxed">
            {meeting.data.description}
          </p>
          
        </div>
      ))
    }
  </div>
</div>