---
import logo from "../assets/bitmap-without-typo-nb.png";
import { siteConfig } from "../data/siteConfig";
---

<footer class="relative bg-clancy-dark text-clancy-white pt-20 pb-10 border-t-2 border-clancy-red/40 overflow-hidden selection:bg-clancy-red selection:text-white">
  <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-[0.08] pointer-events-none"></div>
  <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-clancy-red/50 to-transparent animate-pulse"></div>

  <div class="max-w-[1300px] mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-12 mb-20">
      
      <div class="col-span-1 sm:col-span-2">
        <div class="flex items-center gap-6 mb-8 group">
          <div class="relative">
            <div class="absolute inset-0 bg-clancy-red/20 blur-3xl rounded-full group-hover:scale-150 transition-transform duration-1000"></div>
            <div class="absolute inset-0 bg-clancy-red/10 blur-md rounded-full group-hover:animate-pulse"></div>
            <img
              src={logo.src}
              alt="SB Logo"
              class="w-20 h-20 object-contain relative z-10 filter brightness-110 drop-shadow-[0_0_15px_rgba(255,0,0,0.6)] transition-all duration-500 group-hover:rotate-[360deg] group-hover:scale-110"
            />
          </div>
          <div class="flex flex-col">
            <h2 class="text-5xl font-black tracking-tighter uppercase leading-none group-hover:text-clancy-red transition-colors duration-500">
              Secta <br/> Banditos
            </h2>
            <div class="mt-3 inline-flex">
               <span class="text-[11px] uppercase tracking-[0.4em] bg-clancy-red text-clancy-dark px-3 py-1 font-black skew-x-[-15deg] hover:skew-x-0 transition-transform duration-300">
                Tema activo: Breach 
               </span>
            </div>
          </div>
        </div>
        <p class="text-sm text-clancy-white/40 leading-relaxed max-w-sm font-bold uppercase tracking-[0.2em] border-l-2 border-clancy-red/30 pl-4 hover:border-clancy-red transition-colors">
          Sitio creado por el Clique de Secta Banditos :D
        </p>
      </div>

      <div>
        <h3 class="text-[12px] uppercase font-black tracking-[0.5em] mb-10 text-clancy-red flex items-center gap-3">
          <span class="w-8 h-[1px] bg-clancy-red"></span>
          Mapa
        </h3>
        <ul class="space-y-5">
          {['Inicio', 'Sobre Nosotros', 'Eventos', 'Galería', 'Merch'].map((item) => (
            <li>
              <a 
                href={item === 'Inicio' ? '/' : `/${item.toLowerCase().replace(' ', '-')}`} 
                class="text-[11px] uppercase font-black tracking-[0.3em] text-clancy-white/40 hover:text-clancy-red hover:translate-x-2 transition-all duration-300 flex items-center gap-2 group"
              >
                <span class="w-0 h-[1px] bg-clancy-red group-hover:w-4 transition-all"></span>
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-[12px] uppercase font-black tracking-[0.5em] mb-10 text-clancy-red flex items-center gap-3">
          <span class="w-8 h-[1px] bg-clancy-red"></span>
          Ubicación
        </h3>
        <div class="space-y-5 text-[11px] uppercase tracking-[0.3em] font-black text-clancy-white/40">
          <div class="flex items-center gap-3 p-2 border border-white/5 hover:bg-clancy-red/5 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-clancy-red animate-bounce">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <p>México 🇲🇽</p>
          </div>
          <div class="flex items-center gap-3 pl-2">
            <span class="w-2 h-2 bg-clancy-red animate-ping"></span>
            <p class="text-clancy-white/60"></p>
          </div>
          <div class="h-[1px] w-full bg-gradient-to-r from-clancy-red/50 to-transparent"></div>
        </div>
      </div>
    </div>

    <div class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="text-[10px] uppercase font-black tracking-[0.5em] text-clancy-white/20 hover:text-clancy-white/50 transition-colors cursor-default">
        © 2026 / SECTA_BANDITOS
      </div>
      
      <div class="flex items-center gap-8 text-[10px] uppercase font-black tracking-[0.6em] text-clancy-white/20">
        <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-clancy-red"></span>
            <span>FAILED PERIMETER ESCAPE</span>
        </div>
        <span class="text-clancy-red/30 italic hover:text-clancy-red transition-colors"></span>
      </div>
    </div>
  </div>
</footer>