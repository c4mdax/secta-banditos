---
import { getCollection } from 'astro:content';
const meetings = await getCollection('meetings');
---

<div class="grid gap-6 md:grid-cols-2">
  {meetings.length > 0 ? (
    meetings.map((meeting) => (
      <div class="bg-base-200 p-8 border-l-4 border-primary hover:bg-clancy-red/10 transition-all group">
        <div class="text-primary font-bold text-xs tracking-widest uppercase mb-2">
          {meeting.data.date}
        </div>
        <h3 class="text-2xl font-heading mb-3 group-hover:tracking-wider transition-all">
          {meeting.data.title}
        </h3>
        <div class="flex items-center gap-2 text-base-content/50 mb-4 text-sm font-medium">
          <span class="text-primary">@</span> {meeting.data.location}
        </div>
        <p class="text-base-content/70 text-sm leading-relaxed">
          {meeting.data.description}
        </p>
      </div>
    ))
  ) : (
    <div class="col-span-full py-10 border border-dashed border-base-content/20 text-center">
      <p class="text-base-content/50 italic">No hay misiones programadas por ahora. ¡Propón una en el grupo!</p>
    </div>
  )}
</div>