---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const galleryEntries = await getCollection('gallery');

// Ordenar por fecha
galleryEntries.sort((a, b) => {
  return new Date(b.data.date || 0).valueOf() - new Date(a.data.date || 0).valueOf();
});
---

<div class="max-w-[1100px] mx-auto px-2 sm:px-6">
  <div class="flex flex-col gap-24 sm:gap-40">
    {
      galleryEntries.map((entry, index) => (
        <div class={`flex flex-col md:flex-row items-center gap-12 md:gap-20 reveal ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          
          <div class="w-full md:w-3/5">
            <div class="relative group overflow-hidden border border-clancy-white/10 bg-black shadow-[0_0_50px_rgba(0,0,0,0.6)]">
              <Image 
                src={entry.data.image} 
                alt={entry.data.title} 
                width={1200}
                height={900}
                /* h-[400px] asegura que en celular la foto tenga buena presencia */
                class="w-full h-[400px] md:h-[500px] object-cover transition-all duration-1000 grayscale-[40%] group-hover:grayscale-0 group-hover:scale-110"
              />
              
              <div class="absolute inset-0 bg-gradient-to-t from-clancy-dark/90 via-transparent to-transparent opacity-50 group-hover:opacity-20 transition-opacity duration-700"></div>
              
              <div class="absolute top-6 left-6 border-t-2 border-l-2 border-clancy-red/60 w-10 h-10 group-hover:w-16 group-hover:h-16 transition-all duration-500"></div>
              <div class="absolute bottom-6 right-6 border-b-2 border-r-2 border-clancy-red/60 w-10 h-10 group-hover:w-16 group-hover:h-16 transition-all duration-500"></div>
              
              <div class="absolute top-6 right-8 flex items-center gap-2 opacity-30 group-hover:opacity-100 transition-opacity">
                <div class="w-2 h-2 bg-clancy-red rounded-full animate-pulse shadow-[0_0_10px_#ff0000]"></div>
                <span class="font-mono text-[8px] uppercase tracking-tighter">Live_Archive</span>
              </div>
            </div>
          </div>

          <div class="w-full md:w-2/5 flex flex-col justify-center px-4 md:px-0">
            <h3 class="text-4xl sm:text-5xl md:text-6xl font-black mb-8 text-clancy-white uppercase tracking-tighter italic leading-none">
              {entry.data.title}
            </h3>
            
            <p class="text-lg md:text-xl text-clancy-white/70 leading-relaxed font-light border-l-4 border-clancy-red pl-8 mb-10 italic">
              {entry.data.description}
            </p>

            {entry.data.date && (
              <div class="flex items-center gap-4 group">
                <div class="relative flex items-center justify-center">
                  <div class="w-2.5 h-2.5 bg-clancy-red rounded-full animate-ping absolute opacity-40"></div>
                  <div class="w-2.5 h-2.5 bg-clancy-red rounded-full relative shadow-[0_0_10px_#ff0000]"></div>
                </div>
                
                <span class="font-mono text-[11px] md:text-xs text-clancy-red font-black uppercase tracking-[0.4em]">
                  Captura: {entry.data.date}
                </span>
              </div>
            )}
          </div>

        </div>
      ))
    }
  </div>
</div>

<style>
  /* Aseguramos que el efecto reveal se aplique a cada fila */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    animation: fadeInUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Escalado de delays para el mapeo si fuera necesario */
  .reveal:nth-child(1) { animation-delay: 0.1s; }
  .reveal:nth-child(2) { animation-delay: 0.3s; }
</style>