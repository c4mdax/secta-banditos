---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import FanMerch from '../components/FanMerch.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

// Assets
import hiveLogo from '../assets/the_hive_merch.jpeg';
import dragonflyLogo from '../assets/dragonfly_merch.png';
import tamagotchiLogo from '../assets/tamagotchi_store.jpg';
import bracelettLogo from '../assets/bracelett_store.png';
import uziLogo from '../assets/uzis.jpg'; 

const merchFeatures = [
  "Libretas, camisetas, llaveros, stickers, peluches, souvenirs y más.",
  "Envíos a toda la República Mexicana 🇲🇽",
  "Artículos personalizables bajo pedido",
  "Hechos por el Clique, pero disponible para tod@s."
];

const hiveFeatures = ["Diseños exclusivos y personalizados", "Envíos a toda la República Mexicana 🇲🇽", "Calidad artesanal en cada pieza"];
const dragonflyFeatures = ["Playeras de alta calidad y estampados únicos", "Técnicas de serigrafía y vinil textil", "Envíos a toda la República Mexicana 🇲🇽"];
const tamagotchiFeatures = ["Impresión digital y diseño gráfico personalizado", "Stickers de alta durabilidad y corte preciso", "Identidad visual", "Envíos a toda la República Mexicana 🇲🇽"];
const bracelettFeatures = ["Brazaletes artesanales", "Materiales seleccionados de alta resistencia", "Diseños personalizados", "Envíos a toda la República Mexicana 🇲🇽"];
const uziFeatures = ["CDs de TØP descontinuados", "Diseños de calidad", "Materiales resistentes", "Envíos a toda la República Mexicana 🇲🇽"];

const vendors = [
  { 
    name: "The Hive Merch", 
    desc: "Libretas, tazas, peluches, ¡y más!.", 
    features: hiveFeatures, 
    img: hiveLogo, 
    color: "#FBBF24", // Honey Yellow
    accent: "#F59E0B",
    link: "https://instagram.com/the_hive_merch", 
    btn: "Contáctanos", 
    flip: false 
  },
  { 
    name: "Dragonfly Merch", 
    desc: "Playeras y estampados de alta resistencia.", 
    features: dragonflyFeatures, 
    img: dragonflyLogo, 
    color: "#FFFFFF", // White
    accent: "#A3A3A3",
    link: "https://www.instagram.com/dragonfly_merchshop?igsh=eWtzcGUzbXo5Yjcy", 
    btn: "Ver Catálogo", 
    flip: true 
  },
  { 
    name: "Tamagotchi Print & Design", 
    desc: "Diseños, pósters, tarjetas y todo para la impresión de alta calidad.", 
    features: tamagotchiFeatures, 
    img: tamagotchiLogo, 
    color: "#2DD4BF", // Turquoise
    accent: "#FEF08A", // Pastel Yellow
    link: "https://www.instagram.com/tamagotchi.printanddesigne?igsh=ZjgxejlzeXRqeXVz", 
    btn: "Solicitar Diseño", 
    flip: false 
  },
  { 
    name: "Bracelett Store", 
    desc: "Brazaletes artesanales.", 
    features: bracelettFeatures, 
    img: bracelettLogo, 
    color: "#D97706", // Elegant Brown/Amber
    accent: "#FDE68A",
    link: "https://www.instagram.com/bracelett_store_?igsh=MWp4a2x3bWQ5czUzNA==", 
    btn: "Explorar Tienda", 
    flip: true 
  },
  { 
    name: "Uzi's CD's Project", 
    desc: "CD's descontinuados de TØP.", 
    features: uziFeatures, 
    img: uziLogo, 
    color: "#EA580C", // Orange
    accent: "#FACC15", // Yellow
    link: "https://www.facebook.com/share/1GTzbErmWF/", 
    btn: "Grabar mi CD", 
    flip: false 
  }
];
---

<Layout title="Merch - Secta Banditos">
  <Navbar />
  
  <main class="relative bg-clancy-dark text-clancy-white min-h-screen py-24 px-6 overflow-hidden" transition:name="main-content">
    <div class="fixed inset-0 pointer-events-none z-10 scanlines opacity-10"></div>

    <div class="max-w-7xl mx-auto relative z-20">
      
      <header class="mb-24 reveal">
        <div class="flex items-center gap-4 mb-8">
          <div class="h-px w-16 bg-clancy-red shadow-[0_0_10px_#ff0000]"></div>
          <span class="text-clancy-red font-black tracking-[0.6em] uppercase text-[10px] md:text-xs flicker-slow">SUMiNiSTRØS // CLiQUE</span>
        </div>
        
        <h1 class="text-7xl md:text-[10rem] font-heading leading-[0.75] uppercase tracking-tighter mb-12">
          Fan <br/>
          <span class="clancy-title-red">Merch</span>
        </h1>

        <div class="border-l border-clancy-red/40 pl-8 py-2 max-w-2xl">
          <ul class="space-y-5">
            {merchFeatures.map((feature, index) => (
              <li class="flex items-center gap-4 group reveal" style={`animation-delay: ${index * 150}ms`}>
                <div class="vibrant-bullet" style="--bullet-clr: #ff0000;"></div>
                <span class="text-[10px] md:text-xs uppercase font-bold tracking-[0.2em] text-clancy-white/70 group-hover:text-white transition-colors">
                  {feature}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </header>

      {vendors.map((vendor, i) => (
        <section class="reveal mb-24" style={`animation-delay: ${i * 100}ms`}>
          <div 
            class="grid md:grid-cols-2 gap-12 items-center bg-white/[0.02] border-y md:border-x border-white/5 p-8 md:p-16 relative group overflow-hidden"
            style={`border-color: ${vendor.color}20; background: linear-gradient(135deg, ${vendor.color}05 0%, transparent 100%);`}
          >
            <div class="absolute -right-20 -top-20 w-64 h-64 blur-[100px] opacity-10 rounded-full" style={`background-color: ${vendor.color};`}></div>
            
            <div class={`${vendor.flip ? 'md:order-2' : 'md:order-1'} relative z-10`}>
              <h2 class="text-5xl md:text-7xl font-heading uppercase leading-[0.9] mb-6 transition-all duration-500 group-hover:tracking-tight" style={`color: ${vendor.color}; text-shadow: 0 0 20px ${vendor.color}40;`}>
                {vendor.name}
              </h2>
              <p class="text-clancy-white/60 text-lg italic mb-8 border-l-2 pl-6 font-light" style={`border-color: ${vendor.accent};`}>
                {vendor.desc}
              </p>
              
              <ul class="space-y-5 mb-10">
                {vendor.features.map((f, idx) => (
                  <li class="flex items-center gap-4 group/item">
                    <div class="vibrant-bullet" style={`--bullet-clr: ${vendor.color}; animation-delay: ${idx * 0.2}s`}></div>
                    <span class="text-[10px] md:text-xs uppercase font-bold tracking-widest text-white/40 group-hover/item:text-white transition-colors">
                      {f}
                    </span>
                  </li>
                ))}
              </ul>

              <a 
                href={vendor.link} 
                target="_blank" 
                class="inline-block border font-black px-10 py-4 uppercase text-[10px] tracking-[0.4em] transition-all skew-x-[-12deg] hover:bg-white hover:text-black"
                style={`border-color: ${vendor.color}; color: ${vendor.color};`}
              >
                {vendor.btn}
              </a>
            </div>

            <div class={`${vendor.flip ? 'md:order-1' : 'md:order-2'} flex justify-center relative`}>
              <div class="relative w-64 h-64 md:w-80 md:h-80 group-hover:scale-105 transition-transform duration-700">
                <div class="absolute -inset-8 opacity-20 blur-2xl rounded-full animate-pulse" style={`background-color: ${vendor.color};`}></div>
                <Image src={vendor.img} alt={vendor.name} class="w-full h-full object-contain relative z-10 filter grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700" />
              </div>
            </div>
          </div>
        </section>
      ))}

      <footer class="mt-32 text-center reveal">
        <div class="w-full h-px bg-gradient-to-r from-transparent via-clancy-red to-transparent opacity-30 mb-12"></div>
        <div class="max-w-2xl mx-auto">
          <p class="text-clancy-red font-black text-xs uppercase tracking-[0.5em] mb-6 flicker-slow">Logística de Entrega</p>
          <p class="text-clancy-white/40 text-[10px] md:text-xs uppercase tracking-[0.25em] leading-relaxed italic">
            La distribución se coordina directamente con los creadores. Mantente alerta a nuestro canal oficial para próximos puntos de entrega en las incursiones.
          </p>
        </div>
      </footer>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  /* VIBRANT ANIMATED BULLET */
  .vibrant-bullet {
    width: 8px;
    height: 8px;
    background-color: var(--bullet-clr);
    transform: rotate(45deg);
    position: relative;
    box-shadow: 0 0 10px var(--bullet-clr);
    animation: bullet-glow 2s infinite ease-in-out;
  }

  .vibrant-bullet::after {
    content: '';
    position: absolute;
    inset: -2px;
    border: 1px solid var(--bullet-clr);
    animation: bullet-pulse 2s infinite ease-out;
  }

  @keyframes bullet-glow {
    0%, 100% { filter: brightness(1) drop-shadow(0 0 2px var(--bullet-clr)); transform: rotate(45deg) scale(1); }
    50% { filter: brightness(1.5) drop-shadow(0 0 8px var(--bullet-clr)); transform: rotate(225deg) scale(1.2); }
  }

  @keyframes bullet-pulse {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  /* BASE STYLES */
  .clancy-title-red {
    color: #ff0000;
    display: inline-block;
    filter: drop-shadow(0 0 20px rgba(255, 0, 0, 0.4));
    font-weight: 900;
    line-height: 0.8;
  }

  .reveal { 
    opacity: 0; 
    transform: translateY(20px); 
    animation: fadeInUp 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; 
  }

  @keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }

  .scanlines { 
    background: repeating-linear-gradient(to bottom, transparent 0px, transparent 2px, rgba(0, 0, 0, 0.3) 2px, rgba(0, 0, 0, 0.3) 4px); 
  }

  .flicker-slow { animation: flicker 4s infinite alternate; }
  @keyframes flicker {
    0%, 19.999%, 22%, 62.999%, 64%, 64.999%, 70%, 100% { opacity: 1; }
    20%, 21.999%, 63%, 63.999%, 65%, 69.999% { opacity: 0.4; }
  }
</style>