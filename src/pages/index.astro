---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Image } from 'astro:assets';

// Assets
import backgroundImage from '../assets/background.webp';
import logoImage from '../assets/sb-logo.png';
---

<Layout title="Inicio - Secta Banditos">
  <Navbar />
  
  <main 
    class="bg-clancy-dark text-clancy-white min-h-screen relative" 
    transition:name="main-content" 
    transition:animate="fade"
  >
    <div class="fixed inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-[0.03] pointer-events-none z-50"></div>

    <section class="relative w-full min-h-[80vh] flex flex-col items-center justify-center overflow-hidden border-b border-clancy-red/30 pt-8 sm:pt-12 pb-8">
      <div class="absolute inset-0 z-0">
        <Image 
          src={backgroundImage} 
          alt="Secta Banditos Background" 
          class="w-full h-full object-cover opacity-20 scale-105 animate-slow-zoom grayscale"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-clancy-dark/95 via-transparent to-clancy-dark"></div>
      </div>

      <div class="relative z-10 text-center px-6 w-full max-w-7xl mx-auto flex flex-col items-center">
        <div class="mb-4 reveal group">
          <div class="relative flex justify-center items-center">
            <div class="absolute inset-0 bg-clancy-red/20 blur-[60px] sm:blur-[100px] rounded-full scale-150 animate-pulse-slow pointer-events-none"></div>
            <div class="absolute w-24 h-24 bg-clancy-red/40 blur-[30px] sm:blur-[50px] rounded-full animate-pulse pointer-events-none"></div>
            
            <Image 
              src={logoImage} 
              alt="Secta Banditos" 
              class="w-52 sm:w-64 md:w-[22rem] lg:w-[28rem] h-auto relative z-10 filter brightness-125 contrast-125 drop-shadow-[0_0_20px_rgba(255,0,0,0.6)] transition-all duration-700 ease-out group-hover:scale-105 animate-float"
            />
          </div>
        </div>

        <div class="flex flex-col items-center gap-4 w-full">
          <div class="flex items-center justify-center gap-3 reveal delay-100">
            <div class="h-[1px] w-8 sm:w-12 bg-clancy-red/40"></div>
            <span class="bg-clancy-red text-clancy-dark font-black tracking-[0.3em] uppercase text-[9px] md:text-xs px-4 py-1 skew-x-[-12deg]">
              Del Clique, para el Clique...
            </span>
            <div class="h-[1px] w-8 sm:w-12 bg-clancy-red/40"></div>
          </div>

          <p class="text-clancy-white/60 text-sm md:text-base max-w-xl mx-auto font-light tracking-[0.2em] uppercase reveal delay-200 px-4 leading-tight">
            Merch, convivencias, eventos y el legado de  <span class="text-clancy-red/80 font-bold ml-1">La Antorcha</span>
          </p>

          <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center items-center reveal delay-300 w-full sm:w-auto mt-2">
            <a href="/about" class="btn-skew relative px-10 py-3 bg-clancy-red text-white overflow-hidden group w-[80%] sm:w-auto transition-all active:scale-95 text-center">
              <span class="relative z-10 font-black uppercase tracking-[0.4em] text-[10px]">Sobre Nosotros</span>
              <div class="absolute inset-0 bg-white translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"></div>
              <span class="absolute inset-0 flex items-center justify-center z-20 text-clancy-dark font-black uppercase tracking-[0.4em] text-[10px] opacity-0 group-hover:opacity-100 transition-opacity">Sobre Nosotros</span>
            </a>

            <a href="/merch" class="btn-skew-reverse relative px-10 py-3 border-2 border-clancy-white/20 text-clancy-white overflow-hidden group w-[80%] sm:w-auto hover:border-clancy-red transition-all active:scale-95 text-center">
              <span class="relative z-10 font-black uppercase tracking-[0.4em] text-[10px] group-hover:text-clancy-red transition-colors">Merch</span>
              <div class="absolute top-0 left-0 w-2 h-2 border-t-2 border-l-2 border-clancy-red opacity-0 group-hover:opacity-100 transition-all duration-300"></div>
              <div class="absolute bottom-0 right-0 w-2 h-2 border-b-2 border-r-2 border-clancy-red opacity-0 group-hover:opacity-100 transition-all duration-300"></div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="relative py-12 sm:py-16 px-6 overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-5xl h-full border-x border-clancy-red/20 pointer-events-none"></div>
      
      <div class="max-w-4xl mx-auto relative">
        <div class="flex flex-col mb-6 reveal delay-100 items-center text-center">
          <div class="flex items-center gap-4 mb-4 w-full">
            <div class="h-[1px] flex-grow bg-clancy-red/20"></div>
            <span class="text-clancy-red font-mono text-[9px] tracking-[0.4em] uppercase"></span>
            <div class="h-[1px] flex-grow bg-clancy-red/20"></div>
          </div>
          <h2 class="text-4xl md:text-6xl font-black tracking-tighter uppercase italic leading-none">
            Nuestro <span class="text-clancy-red drop-shadow-[0_0_15px_rgba(255,0,0,0.4)]">Espacio</span>
          </h2>
        </div>

        <div class="text-center reveal delay-200">
          <p class="text-lg md:text-1xl font-light leading-relaxed text-clancy-white/90 mb-4 tracking-wide italic px-4">
            Bienvenidos a <span class="text-clancy-red font-bold">nuestra secta</span>. Somos un <span class="text-clancy-white border-b border-clancy-red/50">Clique mexicano</span> 🇲🇽, unidos para organizar eventos, compartir recuerdos, promocionar nuestra merch, compartir fanarts, y siempre proteger el legado de la antorcha.
          </p>
        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>

<style>
  .btn-skew { clip-path: polygon(10% 0, 100% 0, 90% 100%, 0% 100%); }
  .btn-skew-reverse { clip-path: polygon(0 0, 90% 0, 100% 100%, 10% 100%); }
  
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }

  @keyframes slow-zoom {
    from { transform: scale(1.02); }
    to { transform: scale(1.05); }
  }
  .animate-slow-zoom { animation: slow-zoom 20s infinite alternate ease-in-out; }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .animate-float { animation: float 6s infinite ease-in-out; }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.2; transform: scale(1.5); }
    50% { opacity: 0.3; transform: scale(1.6); }
  }
  .animate-pulse-slow { animation: pulse-slow 8s infinite ease-in-out; }

  .delay-100 { animation-delay: 0.2s; }
  .delay-200 { animation-delay: 0.4s; }
  .delay-300 { animation-delay: 0.6s; }
</style>